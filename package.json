{
  "name": "native-signal-ui",
  "version": "0.3.5",
  "description": "A super-simple signal-based UI framework based on my custom signal framework `native-signal`",
  "type": "module",
  "files": [
    "dist",
    "src",
    "docs",
    "AGENTS.md",
    "llms.txt"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": [
    "**/*.css",
    "./src/components/*.ts",
    "./dist/components/*.js"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "happy-dom": "^15.7.4",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "native-signal": "^0.5.16"
  }
}
